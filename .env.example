# Gemini API Configuration (Get yours from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Signing Secret (change this to a secure random string in production)
JWT_SECRET=supersecretkeyforlocaldevelopmentonly

# Port to bind the server on
PORT=8000

# Database URL for your backend. Use a hosted Supabase/Postgres URL in production.
# Example: DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./orchestrator.db

# Optional Supabase project info for client integration or admin tooling.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
